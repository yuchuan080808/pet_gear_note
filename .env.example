# Qwen / DashScope OpenAI-compatible API, good for first trials.
LLM_API_KEY=sk-your-dashscope-key-here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# Later, switch to OpenAI or another OpenAI-compatible provider by changing
# the three LLM_* values above.

# Optional AutoCLI overrides.
# Set this when autocli is installed but not visible to auto_update.bat/Python.
# AUTOCLI_PATH=C:\Users\Administrator\AppData\Roaming\npm\autocli.cmd
# AUTOCLI_BESTSELLERS_COMMAND=autocli amazon bestsellers {url} -f json
# AUTOCLI_PRODUCT_COMMAND=autocli amazon product {asin} -f json
